{
  "mcpServers": {
    "graphify": {
      "type": "stdio",
      "command": "graphify-mcp",
      "args": ["graphify-out/graph.json"],
      "env": {
        "PATH": "${HOME}/.local/bin:${PATH}"
      }
    },
    "next-devtools": {
      "command": "bunx",
      "args": ["-y", "next-devtools-mcp@latest"]
    },
    "playwright": {
      "command": "bunx",
      "args": ["@playwright/mcp@latest"]
    },
    "terraform": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "hashicorp/terraform-mcp-server"]
    }
  }
}
