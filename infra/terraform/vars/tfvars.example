# Common
aws_region   = "ap-northeast-1"
project_name = "boilerplate-template"
environment  = "dev"             # dev | prod
root_domain  = "ahmax99.online"

# GitHub OIDC variables
github_org = "ahmax99"

# Backend Environment Variables
database_url       = "postgresql://user:password@host/database"
backend_sentry_dsn = "https://your-backend-sentry-dsn"

# Frontend Environment Variables
contact_to_email    = "contact@example.com"
from_email          = "no-reply@example.com"
resend_api_key      = "" # Get from resend.com
frontend_sentry_dsn = "https://your-frontend-sentry-dsn"

# Google OAuth (create credentials at console.cloud.google.com)
google_client_id     = ""
google_client_secret = ""

# Session
session_secret = "" # Generate with: openssl rand -base64 32

# Cross-account (multi-account dev/prod separation)
source_ecr_account_id        = "" # e.g. "000000000000"
promotion_grantee_account_id = "" # e.g. "000000000000"
