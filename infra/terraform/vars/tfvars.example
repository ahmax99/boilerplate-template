# Common
aws_region   = "ap-northeast-1"
project_name = "boilerplate-template"
environment  = "dev"             # dev | prod
root_domain  = "ahmax99.online"

# GitHub OIDC variables
github_org                   = "ahmax99"
create_github_oidc_provider  = true # true for the first env applied (dev); false for the others

# Backend Environment Variables
database_url = "postgresql://user:password@host/database"
sentry_dsn   = "https://your-sentry-dsn"

# Frontend Environment Variables
contact_to_email = "contact@example.com"
from_email       = "no-reply@example.com"
resend_api_key   = "" # Get from resend.com

# Google OAuth (create credentials at console.cloud.google.com)
google_client_id     = ""
google_client_secret = ""

# Session
session_secret = "" # Generate with: openssl rand -base64 32
