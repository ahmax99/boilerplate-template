{
  "name": "@shared/neon",
  "version": "0.1.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "bun --bun prisma generate && tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "check-types": "tsc --noEmit",
    "db:generate": "bun --bun prisma generate",
    "db:deploy": "bun --bun prisma migrate deploy",
    "db:push": "bun --bun prisma db push",
    "db:pull": "bun --bun prisma db pull",
    "db:reset": "bun --bun prisma migrate reset",
    "db:seed": "bun --bun prisma db seed"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "nanoid": "^5.1.6",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@shared/typescript-config": "workspace:*",
    "@types/node": "^25.3.5",
    "@types/ws": "^8.18.1",
    "prisma": "^7.4.2",
    "typescript": "^5.9.3"
  }
}
