{
  "name": "@shared/neon",
  "version": "1.0.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "type": "module",
  "scripts": {
    "prebuild": "bun run db:generate",
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "check-types": "tsc --noEmit",
    "db:generate": "bun --bun prisma generate",
    "db:deploy": "bun --bun prisma migrate deploy",
    "db:push": "bun --bun prisma db push",
    "db:pull": "bun --bun prisma db pull",
    "db:reset": "bun --bun prisma migrate reset",
    "db:seed": "bun --bun prisma db seed"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "nanoid": "^5.1.7",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@shared/typescript-config": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "prisma": "^7.6.0",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "hono": "^4.11.7",
    "@hono/node-server": "^1.19.10"
  }
}
