# Dependencies
**/node_modules
.pnp
.pnp.js

# Local env files
.env*
!.env.example

# Testing
coverage
*.test.ts
*.spec.ts

# Turbo
**/.turbo

# Vercel
.vercel

# Build Outputs
.next/
out/
build
dist
storybook-static
tsconfig.tsbuildinfo
next-env.d.ts

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Prisma
**/prisma/generated

# Graphify — fully regenerated locally
graphify-out/

# Misc
.DS_Store
*.pem

# Local .terraform directories
**/.terraform/*

# Lambda@Edge zip artifacts (regenerated by terraform from the .tftpl templates)
**/function/*.zip

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore .fallow state files
.fallow/

# Claude Code related files
/.claude/settings.local.json
/.claude/plans/*
!/.claude/plans/.gitkeep
/.claude/hooks/*.log
.superpowers/
docs/superpowers/**
docs/specs/**

# Impeccable: machine-local caches + per-developer overrides.
**/.impeccable/hook.cache.json
**/.impeccable/config.local.json

# backlog-runner ephemeral loop state (per-issue, in the main repo)
/.claude/backlog-state/*
!/.claude/backlog-state/.gitkeep
.agent-state.json
.qa-report.md

# backlog-runner per-issue worktrees (native tool or superpowers fallback)
/.worktrees/
/.claude/worktrees/
