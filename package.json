{
  "name": "boilerplate-template",
  "version": "1.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check-updates": "bun outdated --recursive",
    "update-packages": "bun update --interactive --latest --recursive",
    "check-mismatches": "bunx syncpack lint",
    "sync-packages": "bunx syncpack update",
    "check-types": "turbo run check-types",
    "check-format": "biome check",
    "format": "biome format --write",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,yml,yaml}": [
      "biome check --staged --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmax99/boilerplate-template.git"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "picomatch": "^2.3.2"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": ["apps/*", "shared/*"],
  "engines": {
    "node": ">=24"
  }
}
