{
  "name": "boilerplate-template",
  "version": "1.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check-updates": "bun outdated --recursive",
    "update-packages": "bun update --interactive --latest --recursive",
    "check-mismatches": "bunx syncpack lint",
    "sync-packages": "bunx syncpack update",
    "check-types": "turbo run check-types",
    "check-format": "biome check",
    "format": "biome format --write",
    "prepare": "lefthook install || true && git config merge.ours.driver true",
    "graphify:install": "$HOME/.local/bin/uv tool install \"graphifyy[mcp]\"",
    "graphify:build": "$HOME/.local/bin/graphify update .",
    "graphify:serve": "$HOME/.local/bin/graphify-mcp graphify-out/graph.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmax99/boilerplate-template.git"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "lefthook": "^2.1.10",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "picomatch": "^2.3.2"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": ["apps/*", "shared/*"],
  "engines": {
    "node": ">=24"
  }
}
