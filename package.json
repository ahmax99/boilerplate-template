{
  "name": "boilerplate-template",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmax99/boilerplate-template.git"
  },
  "workspaces": [
    "apps/*",
    "shared/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check-updates": "bun outdated --recursive",
    "update-packages": "bun update --interactive --latest --recursive",
    "check-mismatches": "bunx syncpack lint",
    "sync-packages": "bunx syncpack update",
    "check-types": "turbo run check-types",
    "check-format": "oxlint && oxfmt --check",
    "format": "oxlint --fix && oxfmt",
    "prepare": "lefthook install || true",
    "graphify:install": "$HOME/.local/bin/uv tool install \"graphifyy[mcp]\"",
    "graphify:build": "$HOME/.local/bin/graphify update .",
    "graphify:serve": "$HOME/.local/bin/graphify-mcp graphify-out/graph.json"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "picomatch": "^2.3.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.11"
}
