{
  "name": "backend-boilerplate",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --env disable",
    "check-types": "tsc --noEmit",
    "dev": "bun --watch --preload ./instrument.ts src/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1090.0",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/client-secrets-manager": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@bogeychan/elysia-logger": "^0.1.10",
    "@casl/ability": "^7.0.1",
    "@casl/prisma": "^2.0.2",
    "@elysia/bearer": "^1.4.4",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@sentry/bun": "^10.66.0",
    "@shared/config": "workspace:*",
    "@shared/neon": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "elysia": "^1.4.29",
    "elysia-helmet": "^3.1.0",
    "jose": "^6.2.3",
    "neverthrow": "^8.2.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shared/typescript-config": "workspace:*",
    "@types/node": "^26.1.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  }
}
