{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/index.{js,jsx,mjs,ts,tsx}", "src/main.{js,jsx,mjs,ts,tsx}"],
  "workspaces": {
    "packages": ["apps/*", "shared/*"]
  },
  "duplicates": {
    "minOccurrences": 3,
    "ignore": ["**/lib/**"],
    "mode": "semantic"
  },
  "rules": {}
}
